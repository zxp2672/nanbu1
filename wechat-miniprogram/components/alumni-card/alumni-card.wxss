/* alumni-card 组件样式 */
.alumni-card {
  display: flex;
  align-items: center;
  padding: 16px;
  background: #0d1b35;
  border-radius: 12px;
  border: 1px solid rgba(0, 212, 255, 0.1);
  margin-bottom: 12px;
  transition: all 0.2s ease;
}

.alumni-card-hover {
  background: #132547;
  transform: scale(0.98);
}

/* 头像区域 */
.avatar-wrapper {
  flex-shrink: 0;
  margin-right: 14px;
}

.avatar {
  width: 52px;
  height: 52px;
  border-radius: 50%;
  background: #1a2a4a;
}

.avatar-placeholder {
  width: 52px;
  height: 52px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  font-weight: 600;
  color: #fff;
}

/* 信息区域 */
.info-wrapper {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

/* 第一行：姓名 + 学校标签 */
.name-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8px;
}

.name {
  font-size: 16px;
  font-weight: 600;
  color: #e0e8ff;
}

.school-tag {
  display: inline-flex;
  align-items: center;
  padding: 2px 8px;
  border-radius: 12px;
  font-size: 11px;
  font-weight: 500;
  border: 1px solid;
}

/* 第二行：职业 · 公司 */
.job-row {
  font-size: 13px;
  color: #7b8ca8;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.job {
  color: #7b8ca8;
}

.separator {
  color: #4a5568;
  margin: 0 2px;
}

.company {
  color: #7b8ca8;
}

/* 第三行：城市 */
.city-row {
  display: flex;
  align-items: center;
  font-size: 12px;
  color: #7b8ca8;
}

.city-icon {
  margin-right: 4px;
  font-size: 12px;
}

.city {
  color: #7b8ca8;
}
