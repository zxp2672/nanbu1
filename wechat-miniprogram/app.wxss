/* 全局样式 - 深色科技风主题 */
page {
  /* CSS 变量定义 */
  --accent: #00d4ff;
  --bg: #050d1a;
  --card: #0d1b35;
  --card-hover: #132547;
  --text: #e0e8ff;
  --text2: #7b8ca8;
  --accent2: #7c3aed;
  --accent3: #00ff88;
  --warn: #ffaa00;
  --danger: #ff4466;
  --radius: 12px;
  --radius-sm: 8px;
  --shadow: 0 4px 20px rgba(0, 212, 255, 0.1);
  --shadow-lg: 0 8px 32px rgba(0, 0, 0, 0.4);
  
  /* 页面基础样式 */
  background-color: var(--bg);
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 14px;
  line-height: 1.6;
  min-height: 100vh;
}

/* 容器 */
.container {
  padding: 16px;
  box-sizing: border-box;
}

.container-sm {
  padding: 12px;
  box-sizing: border-box;
}

.container-lg {
  padding: 24px;
  box-sizing: border-box;
}

/* 卡片 */
.card {
  background: var(--card);
  border-radius: var(--radius);
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: var(--shadow);
  border: 1px solid rgba(0, 212, 255, 0.1);
}

.card-hover {
  background: var(--card-hover);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.card-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--text);
}

.card-subtitle {
  font-size: 12px;
  color: var(--text2);
}

/* 按钮 */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10px 20px;
  border-radius: var(--radius-sm);
  font-size: 14px;
  font-weight: 500;
  border: none;
  cursor: pointer;
  transition: all 0.2s ease;
}

.btn-primary {
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  color: #fff;
}

.btn-primary:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.btn-secondary {
  background: var(--card);
  color: var(--text);
  border: 1px solid rgba(0, 212, 255, 0.3);
}

.btn-secondary:active {
  background: var(--card-hover);
}

.btn-danger {
  background: var(--danger);
  color: #fff;
}

.btn-success {
  background: var(--accent3);
  color: #000;
}

.btn-warning {
  background: var(--warn);
  color: #000;
}

.btn-sm {
  padding: 6px 12px;
  font-size: 12px;
}

.btn-lg {
  padding: 14px 28px;
  font-size: 16px;
}

.btn-block {
  width: 100%;
}

.btn-outline {
  background: transparent;
  border: 1px solid var(--accent);
  color: var(--accent);
}

.btn-outline:active {
  background: rgba(0, 212, 255, 0.1);
}

/* 标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4px 10px;
  border-radius: 20px;
  font-size: 11px;
  font-weight: 500;
}

.tag-primary {
  background: rgba(0, 212, 255, 0.15);
  color: var(--accent);
  border: 1px solid rgba(0, 212, 255, 0.3);
}

.tag-secondary {
  background: rgba(123, 140, 168, 0.15);
  color: var(--text2);
}

.tag-success {
  background: rgba(0, 255, 136, 0.15);
  color: var(--accent3);
}

.tag-warning {
  background: rgba(255, 170, 0, 0.15);
  color: var(--warn);
}

.tag-danger {
  background: rgba(255, 68, 102, 0.15);
  color: var(--danger);
}

/* 徽章 */
.badge {
  position: absolute;
  top: -4px;
  right: -4px;
  min-width: 16px;
  height: 16px;
  padding: 0 4px;
  background: var(--danger);
  color: #fff;
  font-size: 10px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 列表 */
.list {
  background: var(--card);
  border-radius: var(--radius);
  overflow: hidden;
}

.list-item {
  display: flex;
  align-items: center;
  padding: 14px 16px;
  border-bottom: 1px solid rgba(0, 212, 255, 0.05);
}

.list-item:last-child {
  border-bottom: none;
}

.list-item:active {
  background: var(--card-hover);
}

.list-item-content {
  flex: 1;
}

.list-item-title {
  font-size: 14px;
  color: var(--text);
  margin-bottom: 4px;
}

.list-item-desc {
  font-size: 12px;
  color: var(--text2);
}

.list-item-arrow {
  color: var(--text2);
  font-size: 12px;
}

/* 输入框 */
.input {
  width: 100%;
  height: 44px;
  padding: 0 14px;
  background: var(--bg);
  border: 1px solid rgba(0, 212, 255, 0.2);
  border-radius: var(--radius-sm);
  color: var(--text);
  font-size: 14px;
  box-sizing: border-box;
}

.input:focus {
  border-color: var(--accent);
  outline: none;
}

.input::placeholder {
  color: var(--text2);
}

.textarea {
  width: 100%;
  min-height: 100px;
  padding: 12px 14px;
  background: var(--bg);
  border: 1px solid rgba(0, 212, 255, 0.2);
  border-radius: var(--radius-sm);
  color: var(--text);
  font-size: 14px;
  box-sizing: border-box;
}

/* 表单 */
.form-group {
  margin-bottom: 16px;
}

.form-label {
  display: block;
  margin-bottom: 8px;
  font-size: 13px;
  color: var(--text2);
}

/* 分割线 */
.divider {
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(0, 212, 255, 0.3), transparent);
  margin: 16px 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48px 24px;
  text-align: center;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 16px;
  opacity: 0.5;
}

.empty-text {
  font-size: 14px;
  color: var(--text2);
}

/* 加载 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px;
}

.loading-spinner {
  width: 20px;
  height: 20px;
  border: 2px solid rgba(0, 212, 255, 0.2);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 文字工具类 */
.text-primary { color: var(--accent); }
.text-secondary { color: var(--text2); }
.text-success { color: var(--accent3); }
.text-warning { color: var(--warn); }
.text-danger { color: var(--danger); }
.text-center { text-align: center; }
.text-right { text-align: right; }
.text-bold { font-weight: 600; }
.text-sm { font-size: 12px; }
.text-lg { font-size: 16px; }
.text-xl { font-size: 18px; }

/* 布局工具类 */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.items-center { align-items: center; }
.justify-between { justify-content: space-between; }
.justify-center { justify-content: center; }
.gap-2 { gap: 8px; }
.gap-4 { gap: 16px; }

/* 间距工具类 */
.mt-2 { margin-top: 8px; }
.mt-4 { margin-top: 16px; }
.mb-2 { margin-bottom: 8px; }
.mb-4 { margin-bottom: 16px; }
.ml-2 { margin-left: 8px; }
.mr-2 { margin-right: 8px; }
.p-2 { padding: 8px; }
.p-4 { padding: 16px; }

/* 状态标签 */
.status-upcoming {
  background: rgba(0, 212, 255, 0.15);
  color: var(--accent);
}

.status-ongoing {
  background: rgba(0, 255, 136, 0.15);
  color: var(--accent3);
}

.status-ended {
  background: rgba(123, 140, 168, 0.15);
  color: var(--text2);
}

/* 渐变背景 */
.bg-gradient {
  background: linear-gradient(135deg, var(--card) 0%, var(--bg) 100%);
}

.bg-gradient-accent {
  background: linear-gradient(135deg, var(--accent), var(--accent2));
}

/* 玻璃态效果 */
.glass {
  background: rgba(13, 27, 53, 0.8);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(0, 212, 255, 0.1);
}
