<!--pages/alumni/alumni.wxml-->
<view class="alumni-page">
  <!-- 搜索栏 -->
  <view class="search-section">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input 
        class="search-input" 
        placeholder="搜索姓名/职业/城市/公司"
        value="{{keyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearch"
      />
    </view>
  </view>

  <!-- 筛选区 -->
  <scroll-view class="filter-section" scroll-x="true">
    <view class="filter-row">
      <!-- 学校选择 -->
      <picker 
        mode="selector" 
        range="{{schools}}" 
        value="{{selectedSchool}}"
        bindchange="onSchoolChange"
        class="filter-picker"
      >
        <view class="filter-tag {{selectedSchool > 0 ? 'active' : ''}}">
          <text class="filter-label">学校</text>
          <text class="filter-value">{{schools[selectedSchool]}}</text>
          <text class="filter-arrow">▼</text>
        </view>
      </picker>

      <!-- 学段选择 -->
      <picker 
        mode="selector" 
        range="{{levels}}" 
        value="{{selectedLevel}}"
        bindchange="onLevelChange"
        class="filter-picker"
      >
        <view class="filter-tag {{selectedLevel > 0 ? 'active' : ''}}">
          <text class="filter-label">学段</text>
          <text class="filter-value">{{levels[selectedLevel]}}</text>
          <text class="filter-arrow">▼</text>
        </view>
      </picker>

      <!-- 年份选择 -->
      <picker 
        mode="selector" 
        range="{{years}}" 
        value="{{selectedYear}}"
        bindchange="onYearChange"
        class="filter-picker"
      >
        <view class="filter-tag {{selectedYear > 0 ? 'active' : ''}}">
          <text class="filter-label">年份</text>
          <text class="filter-value">{{years[selectedYear]}}</text>
          <text class="filter-arrow">▼</text>
        </view>
      </picker>

      <!-- 班级选择 -->
      <picker 
        mode="selector" 
        range="{{classes}}" 
        value="{{selectedClass}}"
        bindchange="onClassChange"
        class="filter-picker"
      >
        <view class="filter-tag {{selectedClass > 0 ? 'active' : ''}}">
          <text class="filter-label">班级</text>
          <text class="filter-value">{{classes[selectedClass]}}</text>
          <text class="filter-arrow">▼</text>
        </view>
      </picker>
    </view>
  </scroll-view>

  <!-- 校友列表 -->
  <view class="alumni-list">
    <block wx:if="{{!loading}}">
      <alumni-card 
        wx:for="{{alumniList}}" 
        wx:key="id" 
        alumni="{{item}}"
      />
    </block>

    <!-- 加载状态 -->
    <view class="loading-state" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && alumniList.length === 0}}">
      <text class="empty-icon">📋</text>
      <text class="empty-text">暂无校友数据</text>
    </view>
  </view>

  <!-- 悬浮添加按钮 -->
  <view class="fab-add" bindtap="showAdd">
    <text class="fab-icon">+</text>
  </view>

  <!-- 添加校友弹窗 -->
  <view class="modal-mask" wx:if="{{showAddForm}}" bindtap="hideAdd">
    <view class="modal-content" catchtap="preventBubble">
      <view class="modal-header">
        <text class="modal-title">添加校友</text>
        <text class="modal-close" bindtap="hideAdd">×</text>
      </view>

      <scroll-view scroll-y="true" class="modal-body">
        <view class="form-group">
          <text class="form-label">姓名 <text class="required">*</text></text>
          <input 
            class="form-input" 
            placeholder="请输入姓名"
            value="{{newAlumni.name}}"
            data-field="name"
            bindinput="onAddFormInput"
          />
        </view>

        <view class="form-group">
          <text class="form-label">学校 <text class="required">*</text></text>
          <picker mode="selector" range="{{schools}}" value="{{schools.indexOf(newAlumni.school)}}" bindchange="onAddSchoolChange">
            <view class="form-picker">
              <text class="{{newAlumni.school ? '' : 'placeholder'}}">{{newAlumni.school || '请选择学校'}}</text>
              <text class="picker-arrow">▼</text>
            </view>
          </picker>
        </view>

        <view class="form-group">
          <text class="form-label">学段 <text class="required">*</text></text>
          <picker mode="selector" range="{{levels}}" value="{{levels.indexOf(newAlumni.level)}}" bindchange="onAddLevelChange">
            <view class="form-picker">
              <text class="{{newAlumni.level ? '' : 'placeholder'}}">{{newAlumni.level || '请选择学段'}}</text>
              <text class="picker-arrow">▼</text>
            </view>
          </picker>
        </view>

        <view class="form-group">
          <text class="form-label">入学年份</text>
          <input 
            class="form-input" 
            type="number"
            placeholder="如：2020"
            value="{{newAlumni.year}}"
            data-field="year"
            bindinput="onAddFormInput"
          />
        </view>

        <view class="form-group">
          <text class="form-label">班级</text>
          <input 
            class="form-input" 
            placeholder="如：1班"
            value="{{newAlumni.classname}}"
            data-field="classname"
            bindinput="onAddFormInput"
          />
        </view>

        <view class="form-group">
          <text class="form-label">电话</text>
          <input 
            class="form-input" 
            type="number"
            placeholder="请输入电话号码"
            value="{{newAlumni.phone}}"
            data-field="phone"
            bindinput="onAddFormInput"
          />
        </view>

        <view class="form-group">
          <text class="form-label">职业</text>
          <input 
            class="form-input" 
            placeholder="请输入职业"
            value="{{newAlumni.job}}"
            data-field="job"
            bindinput="onAddFormInput"
          />
        </view>

        <view class="form-group">
          <text class="form-label">公司</text>
          <input 
            class="form-input" 
            placeholder="请输入公司名称"
            value="{{newAlumni.company}}"
            data-field="company"
            bindinput="onAddFormInput"
          />
        </view>

        <view class="form-group">
          <text class="form-label">城市</text>
          <input 
            class="form-input" 
            placeholder="请输入所在城市"
            value="{{newAlumni.city}}"
            data-field="city"
            bindinput="onAddFormInput"
          />
        </view>

        <view class="form-group">
          <text class="form-label">个人简介</text>
          <textarea 
            class="form-textarea" 
            placeholder="请输入个人简介"
            value="{{newAlumni.bio}}"
            data-field="bio"
            bindinput="onAddFormInput"
          />
        </view>
      </scroll-view>

      <view class="modal-footer">
        <button class="btn-cancel" bindtap="hideAdd">取消</button>
        <button class="btn-submit" bindtap="submitAdd">提交</button>
      </view>
    </view>
  </view>
</view>
