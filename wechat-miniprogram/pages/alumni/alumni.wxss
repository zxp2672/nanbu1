/* pages/alumni/alumni.wxss */

/* 页面容器 */
.alumni-page {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 80px;
}

/* 搜索区域 */
.search-section {
  padding: 12px 16px;
  background: var(--card);
  border-bottom: 1px solid rgba(0, 212, 255, 0.1);
}

.search-box {
  display: flex;
  align-items: center;
  background: var(--bg);
  border-radius: 20px;
  padding: 0 14px;
  border: 1px solid rgba(0, 212, 255, 0.2);
}

.search-icon {
  font-size: 14px;
  margin-right: 8px;
  opacity: 0.6;
}

.search-input {
  flex: 1;
  height: 36px;
  font-size: 14px;
  color: var(--text);
  background: transparent;
}

.search-input::placeholder {
  color: var(--text2);
}

/* 筛选区域 */
.filter-section {
  background: var(--card);
  padding: 12px 16px;
  white-space: nowrap;
  border-bottom: 1px solid rgba(0, 212, 255, 0.1);
}

.filter-row {
  display: inline-flex;
  gap: 10px;
}

.filter-picker {
  flex-shrink: 0;
}

.filter-tag {
  display: inline-flex;
  align-items: center;
  padding: 6px 12px;
  background: var(--bg);
  border-radius: 16px;
  border: 1px solid rgba(0, 212, 255, 0.2);
  gap: 6px;
}

.filter-tag.active {
  background: rgba(0, 212, 255, 0.15);
  border-color: var(--accent);
}

.filter-label {
  font-size: 11px;
  color: var(--text2);
}

.filter-value {
  font-size: 13px;
  color: var(--text);
}

.filter-tag.active .filter-value {
  color: var(--accent);
}

.filter-arrow {
  font-size: 10px;
  color: var(--text2);
}

/* 校友列表 */
.alumni-list {
  padding: 12px 16px;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48px 0;
}

.loading-spinner {
  width: 32px;
  height: 32px;
  border: 3px solid rgba(0, 212, 255, 0.2);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 12px;
  font-size: 13px;
  color: var(--text2);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64px 24px;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 16px;
  opacity: 0.6;
}

.empty-text {
  font-size: 14px;
  color: var(--text2);
}

/* 悬浮添加按钮 */
.fab-add {
  position: fixed;
  right: 20px;
  bottom: 100px;
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 16px rgba(0, 212, 255, 0.4);
  z-index: 100;
}

.fab-add:active {
  transform: scale(0.95);
  opacity: 0.9;
}

.fab-icon {
  font-size: 28px;
  color: #fff;
  font-weight: 300;
}

/* 弹窗遮罩 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 弹窗内容 */
.modal-content {
  width: 90%;
  max-width: 360px;
  max-height: 80vh;
  background: var(--card);
  border-radius: 16px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  border: 1px solid rgba(0, 212, 255, 0.2);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 20px;
  border-bottom: 1px solid rgba(0, 212, 255, 0.1);
}

.modal-title {
  font-size: 17px;
  font-weight: 600;
  color: var(--text);
}

.modal-close {
  font-size: 24px;
  color: var(--text2);
  padding: 0 8px;
}

.modal-body {
  flex: 1;
  padding: 16px 20px;
  max-height: 55vh;
}

/* 表单样式 */
.form-group {
  margin-bottom: 16px;
}

.form-label {
  display: block;
  font-size: 13px;
  color: var(--text2);
  margin-bottom: 8px;
}

.required {
  color: var(--danger);
}

.form-input {
  width: 100%;
  height: 44px;
  padding: 0 14px;
  background: var(--bg);
  border: 1px solid rgba(0, 212, 255, 0.2);
  border-radius: 8px;
  color: var(--text);
  font-size: 14px;
  box-sizing: border-box;
}

.form-input::placeholder {
  color: var(--text2);
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 44px;
  padding: 0 14px;
  background: var(--bg);
  border: 1px solid rgba(0, 212, 255, 0.2);
  border-radius: 8px;
  color: var(--text);
  font-size: 14px;
}

.form-picker .placeholder {
  color: var(--text2);
}

.picker-arrow {
  font-size: 10px;
  color: var(--text2);
}

.form-textarea {
  width: 100%;
  min-height: 80px;
  padding: 12px 14px;
  background: var(--bg);
  border: 1px solid rgba(0, 212, 255, 0.2);
  border-radius: 8px;
  color: var(--text);
  font-size: 14px;
  box-sizing: border-box;
}

.form-textarea::placeholder {
  color: var(--text2);
}

/* 弹窗底部按钮 */
.modal-footer {
  display: flex;
  gap: 12px;
  padding: 16px 20px;
  border-top: 1px solid rgba(0, 212, 255, 0.1);
}

.btn-cancel {
  flex: 1;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg);
  border: 1px solid rgba(0, 212, 255, 0.2);
  border-radius: 8px;
  color: var(--text2);
  font-size: 14px;
}

.btn-submit {
  flex: 1;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  border-radius: 8px;
  color: #fff;
  font-size: 14px;
  font-weight: 500;
  border: none;
}

.btn-submit:active {
  opacity: 0.9;
}
