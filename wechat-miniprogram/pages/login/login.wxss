/* 登录页样式 - 深色科技风 */

.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--bg) 0%, #0a1628 100%);
  padding: 40px 24px;
  box-sizing: border-box;
}

/* 品牌区 */
.brand-section {
  text-align: center;
  margin-bottom: 40px;
}

.brand-icon {
  display: block;
  font-size: 64px;
  margin-bottom: 16px;
}

.brand-title {
  display: block;
  font-size: 22px;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 8px;
  text-shadow: 0 0 20px rgba(0, 212, 255, 0.3);
}

.brand-subtitle {
  display: block;
  font-size: 14px;
  color: var(--text2);
}

/* 登录表单 */
.login-form {
  background: rgba(13, 27, 53, 0.6);
  border: 1px solid rgba(0, 212, 255, 0.15);
  border-radius: var(--radius);
  padding: 24px;
  margin-bottom: 24px;
  backdrop-filter: blur(10px);
}

.login-form .form-group {
  margin-bottom: 20px;
}

.login-form .form-group:last-of-type {
  margin-bottom: 24px;
}

.login-form .form-label {
  display: block;
  font-size: 13px;
  color: var(--text2);
  margin-bottom: 8px;
}

.login-form .input {
  width: 100%;
  height: 48px;
  padding: 0 16px;
  background: var(--bg);
  border: 1px solid rgba(0, 212, 255, 0.2);
  border-radius: var(--radius-sm);
  color: var(--text);
  font-size: 15px;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

.login-form .input:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 2px rgba(0, 212, 255, 0.1);
}

.login-form .input::placeholder {
  color: var(--text2);
}

.login-btn {
  height: 48px;
  line-height: 48px;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  border: none;
  border-radius: var(--radius-sm);
  color: #fff;
  font-size: 16px;
  font-weight: 600;
  transition: all 0.3s ease;
}

.login-btn::after {
  border: none;
}

.login-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.login-btn[disabled] {
  opacity: 0.6;
  background: linear-gradient(135deg, #3a5a7a, #4a3a6a);
}

/* 演示账号区 */
.demo-section {
  background: rgba(13, 27, 53, 0.4);
  border: 1px solid rgba(0, 212, 255, 0.1);
  border-radius: var(--radius);
  overflow: hidden;
}

.demo-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 16px;
  background: rgba(0, 212, 255, 0.05);
  border-bottom: 1px solid rgba(0, 212, 255, 0.1);
}

.demo-title {
  font-size: 14px;
  font-weight: 600;
  color: var(--text);
}

.demo-toggle {
  font-size: 12px;
  color: var(--accent);
}

.demo-content {
  padding: 8px;
}

.demo-item {
  display: flex;
  align-items: center;
  padding: 12px;
  margin-bottom: 8px;
  background: rgba(0, 212, 255, 0.05);
  border-radius: var(--radius-sm);
  border: 1px solid rgba(0, 212, 255, 0.1);
  transition: all 0.2s ease;
}

.demo-item:last-child {
  margin-bottom: 0;
}

.demo-item:active {
  background: rgba(0, 212, 255, 0.1);
  transform: scale(0.99);
}

.demo-role {
  width: 70px;
  flex-shrink: 0;
}

.role-tag {
  display: inline-block;
  padding: 3px 8px;
  border-radius: 4px;
  font-size: 11px;
  font-weight: 500;
}

.role-admin {
  background: rgba(255, 68, 102, 0.2);
  color: var(--danger);
  border: 1px solid rgba(255, 68, 102, 0.3);
}

.role-school {
  background: rgba(0, 212, 255, 0.2);
  color: var(--accent);
  border: 1px solid rgba(0, 212, 255, 0.3);
}

.role-user {
  background: rgba(0, 255, 136, 0.2);
  color: var(--accent3);
  border: 1px solid rgba(0, 255, 136, 0.3);
}

.demo-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  margin-left: 12px;
}

.demo-account {
  font-size: 14px;
  color: var(--text);
  font-weight: 500;
  margin-bottom: 2px;
}

.demo-password {
  font-size: 12px;
  color: var(--text2);
}

.demo-arrow {
  font-size: 18px;
  color: var(--text2);
  margin-left: 8px;
}
