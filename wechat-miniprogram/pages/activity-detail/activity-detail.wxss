/* pages/activity-detail/activity-detail.wxss */
.activity-detail-page {
  min-height: 100vh;
  background: var(--bg);
  padding: 16px;
  padding-bottom: 100px;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80px 24px;
}

.loading-spinner {
  width: 40px;
  height: 40px;
  border: 3px solid rgba(0, 212, 255, 0.2);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16px;
}

.loading-text {
  font-size: 14px;
  color: var(--text2);
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 标题区 */
.header-section {
  margin-bottom: 16px;
}

.title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
}

.activity-title {
  flex: 1;
  font-size: 20px;
  font-weight: 700;
  color: var(--text);
  line-height: 1.4;
}

.status-badge {
  flex-shrink: 0;
  padding: 6px 12px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 500;
  border: 1px solid;
}

/* 信息卡片 */
.info-card {
  background: var(--card);
  border-radius: var(--radius);
  padding: 16px;
  margin-bottom: 16px;
  border: 1px solid rgba(0, 212, 255, 0.1);
}

.info-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16px;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-icon {
  font-size: 18px;
  margin-right: 12px;
  margin-top: 2px;
}

.info-content {
  flex: 1;
}

.info-label {
  display: block;
  font-size: 12px;
  color: var(--text2);
  margin-bottom: 4px;
}

.info-value {
  display: block;
  font-size: 14px;
  color: var(--text);
  line-height: 1.5;
}

.info-value.description {
  line-height: 1.8;
  white-space: pre-wrap;
}

/* 报名卡片 */
.signup-card {
  background: var(--card);
  border-radius: var(--radius);
  padding: 16px;
  margin-bottom: 16px;
  border: 1px solid rgba(0, 212, 255, 0.1);
}

.signup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.signup-title {
  font-size: 15px;
  font-weight: 600;
  color: var(--text);
}

.signup-count {
  font-size: 14px;
  color: var(--accent);
  font-weight: 500;
}

/* 进度条 */
.progress-bar {
  margin-top: 8px;
}

.progress-track {
  height: 8px;
  background: var(--bg);
  border-radius: 4px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--accent), var(--accent2));
  border-radius: 4px;
  transition: width 0.3s ease;
}

/* 报名人员列表卡片 */
.signup-list-card {
  background: var(--card);
  border-radius: var(--radius);
  padding: 16px;
  margin-bottom: 16px;
  border: 1px solid rgba(0, 212, 255, 0.1);
}

.signup-list-header {
  margin-bottom: 12px;
  padding-bottom: 12px;
  border-bottom: 1px solid rgba(0, 212, 255, 0.05);
}

.signup-list-title {
  font-size: 15px;
  font-weight: 600;
  color: var(--text);
}

.signup-list {
  display: flex;
  flex-direction: column;
}

.signup-item {
  display: flex;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid rgba(0, 212, 255, 0.05);
}

.signup-item:last-child {
  border-bottom: none;
}

.signup-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12px;
  overflow: hidden;
  flex-shrink: 0;
}

.avatar-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.avatar-text {
  font-size: 16px;
  font-weight: 600;
  color: #fff;
}

.signup-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.signup-name {
  font-size: 14px;
  color: var(--text);
  font-weight: 500;
  margin-bottom: 2px;
}

.signup-school {
  font-size: 12px;
  color: var(--text2);
}

.signup-time {
  font-size: 12px;
  color: var(--text2);
  flex-shrink: 0;
}

/* 暂无报名 */
.empty-signup {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 24px;
  background: var(--card);
  border-radius: var(--radius);
  border: 1px solid rgba(0, 212, 255, 0.1);
  margin-bottom: 16px;
}

.empty-icon {
  font-size: 40px;
  margin-bottom: 12px;
  opacity: 0.5;
}

.empty-text {
  font-size: 14px;
  color: var(--text2);
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 12px 16px 24px;
  background: var(--bg);
  border-top: 1px solid rgba(0, 212, 255, 0.1);
  z-index: 100;
}

.action-btn {
  width: 100%;
  height: 48px;
  border-radius: var(--radius-sm);
  font-size: 16px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.action-btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  color: #fff;
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-primary.disabled {
  background: var(--text2);
  opacity: 0.5;
}

.btn-warning {
  background: rgba(255, 68, 102, 0.15);
  color: var(--danger);
  border: 1px solid rgba(255, 68, 102, 0.3);
}

.btn-warning:active {
  background: rgba(255, 68, 102, 0.25);
}
