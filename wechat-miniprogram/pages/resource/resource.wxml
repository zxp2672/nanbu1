<!--pages/resource/resource.wxml-->
<view class="resource-page">
  <!-- 分类标签栏 -->
  <scroll-view class="category-bar" scroll-x="true" show-scrollbar="false">
    <view 
      class="category-item {{activeCategory === item.key ? 'active' : ''}}"
      wx:for="{{categories}}"
      wx:key="key"
      bindtap="switchCategory"
      data-category="{{item.key}}"
    >
      {{item.label}}
    </view>
  </scroll-view>

  <!-- 资源列表 -->
  <view class="resource-list">
    <resource-card
      wx:for="{{resourceList}}"
      wx:key="id"
      resource="{{item}}"
      currentUserId="{{currentUserId}}"
      bind:delete="onDeleteResource"
    />
    
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{resourceList.length === 0 && !loading}}">
      <text class="empty-icon">📦</text>
      <text class="empty-text">暂无资源</text>
    </view>
    
    <!-- 加载状态 -->
    <view class="loading" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
    </view>
  </view>

  <!-- 悬浮添加按钮 -->
  <view class="fab-btn" bindtap="showAdd">
    <text class="fab-icon">+</text>
  </view>

  <!-- 添加资源弹窗 -->
  <view class="modal-mask" wx:if="{{showAddForm}}" bindtap="hideAdd">
    <view class="modal-content" catchtap="preventBubble">
      <view class="modal-header">
        <text class="modal-title">发布资源</text>
        <text class="modal-close" bindtap="hideAdd">×</text>
      </view>
      
      <view class="modal-body">
        <!-- 标题 -->
        <view class="form-group">
          <text class="form-label">标题</text>
          <input 
            class="input" 
            placeholder="请输入资源标题"
            value="{{newResource.title}}"
            data-field="title"
            bindinput="onAddInput"
          />
        </view>
        
        <!-- 类型 -->
        <view class="form-group">
          <text class="form-label">类型</text>
          <picker bindchange="onTypeChange" value="{{['job', 'project', 'invest', 'other'].indexOf(newResource.type)}}" range="{{['招聘', '项目', '投资', '其他']}}">
            <view class="picker input">
              {{newResource.type === 'job' ? '招聘' : newResource.type === 'project' ? '项目' : newResource.type === 'invest' ? '投资' : '其他'}}
              <text class="picker-arrow">▼</text>
            </view>
          </picker>
        </view>
        
        <!-- 描述 -->
        <view class="form-group">
          <text class="form-label">描述</text>
          <textarea 
            class="textarea" 
            placeholder="请输入资源描述"
            value="{{newResource.description}}"
            data-field="description"
            bindinput="onAddInput"
            maxlength="500"
          />
        </view>
        
        <!-- 联系方式 -->
        <view class="form-group">
          <text class="form-label">联系方式</text>
          <input 
            class="input" 
            placeholder="请输入联系方式（电话/微信/邮箱）"
            value="{{newResource.contact}}"
            data-field="contact"
            bindinput="onAddInput"
          />
        </view>
      </view>
      
      <view class="modal-footer">
        <button class="btn btn-secondary" bindtap="hideAdd">取消</button>
        <button class="btn btn-primary" bindtap="submitResource">发布</button>
      </view>
    </view>
  </view>
</view>
