/* pages/resource/resource.wxss */
.resource-page {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 80px;
}

/* 分类标签栏 */
.category-bar {
  background: var(--card);
  border-bottom: 1px solid rgba(0, 212, 255, 0.1);
  white-space: nowrap;
}

.category-item {
  display: inline-block;
  padding: 14px 20px;
  font-size: 14px;
  color: var(--text2);
  position: relative;
}

.category-item.active {
  color: var(--accent);
  font-weight: 600;
}

.category-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20px;
  right: 20px;
  height: 2px;
  background: var(--accent);
  border-radius: 1px;
}

/* 资源列表 */
.resource-list {
  padding: 16px;
}

/* 悬浮添加按钮 */
.fab-btn {
  position: fixed;
  right: 20px;
  bottom: 30px;
  width: 56px;
  height: 56px;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 16px rgba(0, 212, 255, 0.4);
  z-index: 100;
}

.fab-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}

.fab-icon {
  font-size: 28px;
  color: #fff;
  font-weight: 300;
}

/* 弹窗遮罩 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 20px;
}

.modal-content {
  background: var(--card);
  border-radius: var(--radius);
  width: 100%;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  border: 1px solid rgba(0, 212, 255, 0.2);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 20px;
  border-bottom: 1px solid rgba(0, 212, 255, 0.1);
}

.modal-title {
  font-size: 17px;
  font-weight: 600;
  color: var(--text);
}

.modal-close {
  font-size: 24px;
  color: var(--text2);
  padding: 0 4px;
}

.modal-body {
  padding: 20px;
  overflow-y: auto;
  flex: 1;
}

.modal-footer {
  display: flex;
  gap: 12px;
  padding: 16px 20px;
  border-top: 1px solid rgba(0, 212, 255, 0.1);
}

.modal-footer .btn {
  flex: 1;
}

/* 表单样式 */
.form-group {
  margin-bottom: 16px;
}

.form-label {
  display: block;
  margin-bottom: 8px;
  font-size: 13px;
  color: var(--text2);
}

.picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-arrow {
  font-size: 10px;
  color: var(--text2);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 24px;
  text-align: center;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 16px;
  opacity: 0.5;
}

.empty-text {
  font-size: 14px;
  color: var(--text2);
}

/* 加载 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40px;
}

.loading-spinner {
  width: 24px;
  height: 24px;
  border: 2px solid rgba(0, 212, 255, 0.2);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
