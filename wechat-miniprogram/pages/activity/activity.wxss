/* pages/activity/activity.wxss */
.activity-page {
  min-height: 100vh;
  background: var(--bg);
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  background: var(--card);
  border-bottom: 1px solid rgba(0, 212, 255, 0.1);
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 14px 8px;
  font-size: 13px;
  color: var(--text2);
  border-bottom: 2px solid transparent;
  transition: all 0.2s;
}

.filter-item.active {
  color: var(--accent);
  border-bottom-color: var(--accent);
  font-weight: 600;
}

/* 活动列表 */
.activity-list {
  padding: 16px;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 24px;
  text-align: center;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 16px;
  opacity: 0.5;
}

.empty-text {
  font-size: 14px;
  color: var(--text2);
}

/* 加载 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40px;
}

.loading-spinner {
  width: 24px;
  height: 24px;
  border: 2px solid rgba(0, 212, 255, 0.2);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
